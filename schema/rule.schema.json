{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ry4nch1n/triplogger-policy-data/schema/rule.schema.json",
  "title": "TripLogger Rules File",
  "description": "Array of visa/tax rules for one country-passport pair (e.g. CN_SG.json = China rules for Singapore passport).",
  "type": "array",
  "items": { "$ref": "#/definitions/Rule" },
  "definitions": {
    "Rule": {
      "type": "object",
      "required": [
        "countryCode",
        "passportCountry",
        "ruleType",
        "displayName",
        "description",
        "thresholdDays"
      ],
      "additionalProperties": false,
      "properties": {
        "countryCode": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "passportCountry": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "ruleType": {
          "type": "string",
          "enum": [
            "SINGLE_ENTRY_LIMIT",
            "ROLLING_WINDOW_LIMIT",
            "CALENDAR_YEAR_THRESHOLD",
            "CONSECUTIVE_YEAR_RULE",
            "VISA_REQUIREMENT"
          ]
        },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 60 },
        "description": { "type": "string", "minLength": 10 },
        "thresholdDays": { "type": "integer", "minimum": 1, "maximum": 3650 },
        "windowDays": { "type": "integer", "minimum": 1, "maximum": 3650 },
        "consecutiveYears": { "type": "integer", "minimum": 1, "maximum": 100 },
        "resetConditionDays": { "type": "integer", "minimum": 1, "maximum": 366 },
        "cautionThresholdPercent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "warningThresholdPercent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "criticalThresholdPercent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "applicableVisaTypes": {
          "type": "array",
          "items": { "$ref": "#/definitions/VisaType" },
          "uniqueItems": true
        },
        "validFrom": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "validUntil": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "isActive": { "type": "boolean" },
        "priority": { "type": "integer", "minimum": 0 },
        "suggestion": { "type": "string" },
        "detailedExplanation": { "type": "string" },
        "actionSteps": {
          "type": "array",
          "items": { "$ref": "#/definitions/ActionStep" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "ruleType": { "const": "ROLLING_WINDOW_LIMIT" } } },
          "then": { "required": ["windowDays"] }
        },
        {
          "if": { "properties": { "ruleType": { "const": "CONSECUTIVE_YEAR_RULE" } } },
          "then": { "required": ["consecutiveYears"] }
        }
      ]
    },
    "VisaType": {
      "type": "string",
      "enum": [
        "VISA_FREE",
        "M_VISA",
        "APEC_ABTC",
        "TOURIST_VISA",
        "WORK_PERMIT",
        "BUSINESS_VISA",
        "OTHER"
      ]
    },
    "ActionStep": {
      "type": "object",
      "required": ["title", "description"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "urlMobile": { "type": "string", "format": "uri" },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "isOnline": { "type": "boolean" }
      }
    }
  }
}
